			}
			handleKey(e) {
				if (!this.root.classList.contains('active')) return;
				if (e.key === 'Escape') { this.root.classList.remove('active'); this.state.mode = 'dial-in'; return; }
				if (e.key === '0' && this.state.mode !== 'dial-in') {
					if (this.state.mode === 'menu') { this.root.classList.remove('active'); this.state.mode = 'dial-in'; }
					else if (this.state.mode === 'msglist') this.menu();
					else if (this.state.mode === 'guidelist') this.menu();
					else if (this.state.mode === 'post') this.messagelist();
					else if (this.state.mode === 'guide') this.guidelist();
					else if (this.state.mode === 'file') this.menu();
					return;
				}
				if (this.state.mode === 'dial-in' && (e.key === ' ' || e.key === 'Enter')) { this.setSeen(); this.menu(); return; }
				if (this.state.mode === 'menu') {
					if (e.key === '1') this.messagelist();
					else if (e.key === '2') this.guidelist();
					else if (e.key === '3') this.filearea();
				}
				else if (this.state.mode === 'msglist') {
					if (e.key === '1') { this.selectedPost = 1; this.currentPostOffset = 0; this.viewpost(); }
					else if (e.key === '0') this.menu();
				}
				else if (this.state.mode === 'guidelist') {
					const num = parseInt(e.key);
					if (num >= 1 && num <= this.guides.length) { this.selectedGuide = num; this.currentPostOffset = 0; this.viewguide(); }
					else if (e.key === '0') this.menu();
				}
				else if (this.state.mode === 'post') {
					if (e.key === 'PageDown') { this.currentPostOffset += 20; this.viewpost(); }
					else if (e.key === 'PageUp') { this.currentPostOffset = Math.max(0, this.currentPostOffset - 20); this.viewpost(); }
					else if (e.key === '0') this.messagelist();
				}
				else if (this.state.mode === 'guide') {
					if (e.key === 'PageDown') { this.currentPostOffset += 20; this.viewguide(); }
					else if (e.key === 'PageUp') { this.currentPostOffset = Math.max(0, this.currentPostOffset - 20); this.viewguide(); }
					else if (e.key === '0') this.guidelist();
				}
				else if (this.state.mode === 'file' && e.key === '1') window.location.href = '/ConnorDedicResume.pdf';
			}
			messagelist() {
				this.state.mode = 'msglist';
				const listing = `┌──────────────────────────────────────────────────────────────────────────────┐
