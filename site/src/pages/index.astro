			handleKey(e) {
				if (!this.root.classList.contains('active')) return;
				if (e.key === 'Escape') { this.root.classList.remove('active'); this.state.mode = 'dial-in'; return; }
				if (e.key === '0' && this.state.mode !== 'dial-in') {
					if (this.state.mode === 'menu') { this.root.classList.remove('active'); this.state.mode = 'dial-in'; }
					else if (this.state.mode === 'msglist') this.menu();
					else if (this.state.mode === 'post') this.messagelist();
					else if (this.state.mode === 'file') this.menu();
					return;
				}
				if (this.state.mode === 'dial-in' && (e.key === ' ' || e.key === 'Enter')) { this.setSeen(); this.menu(); return; }
				if (this.state.mode === 'menu') {
					if (e.key === '1') this.messagelist();
					else if (e.key === '2') this.filearea();
				}
				else if (this.state.mode === 'msglist') {
					if (e.key >= '1' && e.key <= '6') { this.selectedPost = parseInt(e.key); this.viewpost(); }
					else if (e.key === '0') this.menu();
				}
				else if (this.state.mode === 'file' && e.key === '1') window.location.href = '/ConnorDedicResume.pdf';
			}
