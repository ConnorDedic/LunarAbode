					const fullText = data.content;
					this.currentPostLines = fullText.split('\n');
					const endLine = Math.min(this.currentPostOffset + 20, this.currentPostLines.length);
					const displayLines = this.currentPostLines.slice(this.currentPostOffset, endLine);
					const displayText = displayLines.join('\n');
					const pageNum = Math.floor(this.currentPostOffset / 20) + 1;
					const totalPages = Math.ceil(this.currentPostLines.length / 20);
					this.content.textContent = displayText;
					this.hint.textContent = `[PgUp/PgDn] scroll (${pageNum}/${totalPages}) | [0] back`;
