	<script>
		class BBS {
			constructor() {
				this.state = { mode: 'dial-in', seenDial: this.getSeen() };
				this.root = document.getElementById('bbs-root');
				this.content = document.getElementById('bbs-content');
				this.hint = document.getElementById('hint');
				this.currentPostOffset = 0;
				this.currentPostLines = [];
				this.guides = [];
				document.getElementById('bbsLink').addEventListener('click', () => this.enter());
				window.addEventListener('keydown', e => this.handleKey(e));
				this.loadGuides();
			}
			async loadGuides() {
				try {
					const controller = new AbortController();
					const timeout = setTimeout(() => controller.abort(), 3000);
					const response = await fetch('/api/guides', { signal: controller.signal });
					clearTimeout(timeout);
					if (response.ok) {
						this.guides = await response.json();
					} else {
						console.error('API returned status:', response.status);
						this.guides = [];
					}
				} catch (error) {
					console.error('Failed to load guides:', error);
					this.guides = [];
				}
			}
			getSeen() { try { return localStorage.getItem('bbs:seen') === '1'; } catch(e) { return false; } }
			setSeen() { try { localStorage.setItem('bbs:seen', '1'); } catch(e) {} }
			enter() { this.root.classList.add('active'); this.state.seenDial ? this.menu() : this.dial(); }
			dial() {
				this.state.mode = 'dial-in';
				this.content.textContent = '\n\nCONNECT 56000\nCARRIER ESTABLISHED\nHANDSHAKE...\n\n       ◄ NETRUNNER INCOMING ►\n\n    WELCOME TO THE NETWORK\n    =========================\n\n\n[PRESS ANY KEY TO CONTINUE]\n';
				this.hint.textContent = '[SPACE/ENTER] skip';
			}
			menu() {
				this.state.mode = 'menu';
				this.content.textContent = `██╗   ██╗ ██████╗ ███████╗    ██╗   ██╗██╗██████╗ ███████╗███╗   ███╗██╗   ██╗███████╗
██║   ██║██╔═══██╗██╔════╝    ██║   ██║██║██╔══██╗██╔════╝████╗ ████║██║   ██║██╔════╝
██║   ██║██║   ██║███████╗    ██║   ██║██║██║  ██║█████╗  ██╔████╔██║██║   ██║███████╗
╚██╗ ██╔╝██║   ██║╚════██║    ╚██╗ ██╔╝██║██║  ██║██╔══╝  ██║╚██╔╝██║██║   ██║╚════██║
 ╚████╔╝ ╚██████╔╝███████║     ╚████╔╝ ██║██████╔╝███████╗██║ ╚═╝ ██║╚██████╔╝███████║
  ╚═══╝   ╚═════╝ ╚══════╝      ╚═══╝  ╚═╝╚═════╝ ╚══════╝╚═╝     ╚═╝ ╚═════╝ ╚══════╝

┌──────────────────────────────────────────────────────────────────────────────┐
│                                                                              │
│  [ 1 ] MESSAGE BOARD                                                         │
│  [ 2 ] FILE AREA                                                             │
│                                                                              │
│  [ 0 ] LOG OFF                                                               │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘`;
				this.hint.textContent = '[1-2] select | [0] exit';
			}
			handleKey(e) {
				if (!this.root.classList.contains('active')) return;
				if (e.key === 'Escape') { this.root.classList.remove('active'); this.state.mode = 'dial-in'; return; }
				if (e.key === '0' && this.state.mode !== 'dial-in') {
					if (this.state.mode === 'menu') { this.root.classList.remove('active'); this.state.mode = 'dial-in'; }
					else if (this.state.mode === 'msglist') this.menu();
					else if (this.state.mode === 'post') this.messagelist();
					else if (this.state.mode === 'file') this.menu();
					return;
				}
				if (this.state.mode === 'dial-in' && (e.key === ' ' || e.key === 'Enter')) { this.setSeen(); this.menu(); return; }
				if (this.state.mode === 'menu') {
					if (e.key === '1') this.messagelist();
					else if (e.key === '2') this.filearea();
				}
				else if (this.state.mode === 'msglist') {
					const num = parseInt(e.key);
					if (num >= 1 && num <= this.guides.length) { this.selectedPost = num; this.currentPostOffset = 0; this.viewpost(); }
					else if (e.key === '0') this.menu();
				}
				else if (this.state.mode === 'post') {
					if (e.key === 'PageDown') { this.currentPostOffset += 20; this.viewpost(); }
					else if (e.key === 'PageUp') { this.currentPostOffset = Math.max(0, this.currentPostOffset - 20); this.viewpost(); }
					else if (e.key === '0') this.messagelist();
				}
				else if (this.state.mode === 'file' && e.key === '1') window.location.href = '/ConnorDedicResume.pdf';
			}
			messagelist() {
				this.state.mode = 'msglist';
				let listing = `┌──────────────────────────────────────────────────────────────────────────────┐
│  MESSAGE BOARD                                                              │
├──────────────────────────────────────────────────────────────────────────────┤
│                                                                              │
`;
				if (this.guides.length === 0) {
					listing += `│  Loading guides...                                                          │
`;
				} else {
					this.guides.forEach(guide => {
						const paddedNum = String(guide.id).padEnd(2);
						const paddedTitle = guide.title.padEnd(50);
						listing += `│  [ ${paddedNum} ] ${paddedTitle} ${guide.date} │
`;
					});
				}
				listing += `│                                                                              │
│  [1-${String(this.guides.length).padEnd(1)}] read | [0] main menu                                               │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘`;
				this.content.textContent = listing;
				this.hint.textContent = `[1-${this.guides.length}] select | [0] main menu`;
			}
			async viewpost() {
				this.state.mode = 'post';
				try {
					const response = await fetch(`/api/guides/${this.selectedPost}`);
					const data = await response.json();
					const fullText = data.content;
					this.currentPostLines = fullText.split('\n');
					const endLine = Math.min(this.currentPostOffset + 20, this.currentPostLines.length);
					const displayLines = this.currentPostLines.slice(this.currentPostOffset, endLine);
					const displayText = displayLines.join('\n');
					const pageNum = Math.floor(this.currentPostOffset / 20) + 1;
					const totalPages = Math.ceil(this.currentPostLines.length / 20);
					this.content.textContent = displayText;
					this.hint.textContent = `[PgUp/PgDn] scroll (${pageNum}/${totalPages}) | [0] back`;
				} catch (error) {
					console.error('Failed to load guide:', error);
					this.content.textContent = 'Error loading guide';
					this.hint.textContent = '[0] back';
				}
			}
			selectPost(n) {
				this.selectedPost = n;
				this.viewpost();
			}
			filearea() {
				this.state.mode = 'file';
				this.content.textContent = `┌──────────────────────────────────────────────────────────────────────────────┐
│  FILE AREA                                                                  │
├──────────────────────────────────────────────────────────────────────────────┤
│                                                                              │
│  [ 1 ] ConnorDedicResume.pdf                                      120 KB   │
│                                                                              │
│  [1] select | [0] main menu                                                │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘`;
				this.hint.textContent = '[1] download | [0] main menu';
			}
		}
		new BBS();
	</script>
</body>
