				this.hint.textContent = '[SPACE/ENTER] skip';
			}
			menu() {
				this.state.mode = 'menu';
				this.content.textContent = `██╗   ██╗ ██████╗ ███████╗    ██╗   ██╗██╗██████╗ ███████╗███╗   ███╗██╗   ██╗███████╗
