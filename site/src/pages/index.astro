				else if (this.state.mode === 'edulist') { if (e.key === '1') this.viewedu1(); else if (e.key === '0') this.menu(); }
				else if (['exp1','exp2','proj1','edu1'].includes(this.state.mode) && e.key === '0') this.menu();
