		class BBS {
			constructor() {
				this.state = { mode: 'dial-in', seenDial: this.getSeen() };
				this.root = document.getElementById('bbs-root');
				this.content = document.getElementById('bbs-content');
				this.hint = document.getElementById('hint');
				this.currentPostOffset = 0;
				this.currentPostLines = [];
				this.guides = [
					{ id: 1, title: 'Windows API Fundamentals', date: '2026-06-20' },
					{ id: 2, title: 'Portable Executable Format', date: '2026-06-20' },
