<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>Connor Dedic | Offensive Security Researcher</title>
	<style>
		:root {
			--bg: #000000;
			--fg: #cccccc;
			--accent-red: #ff0000;
			--accent-bright-red: #ff3333;
			--accent-yellow: #ffff00;
			--accent-green: #00ff00;
			--text-muted: #666666;
			--border: #333333;
		}

		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html {
			color-scheme: dark;
		}

		body {
			background: var(--bg);
			color: var(--fg);
			font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, monospace;
			line-height: 1.6;
		}

		body.bbs-active {
			overflow: hidden;
		}

		.container {
			max-width: 800px;
			margin: 0 auto;
			padding: 2rem;
			min-height: 100vh;
			display: flex;
			flex-direction: column;
			justify-content: space-between;
		}

		.header {
			padding: 3rem 0;
		}

		.name {
			font-size: 2.5rem;
			font-weight: 700;
			margin-bottom: 0.5rem;
			letter-spacing: -1px;
		}

		.tagline {
			font-size: 1.1rem;
			color: var(--text-muted);
			margin-bottom: 1rem;
		}

		.bio {
			color: var(--fg);
			line-height: 1.8;
			margin: 2rem 0;
		}

		.section {
			margin: 3rem 0;
		}

		.section-title {
			font-size: 0.9rem;
			text-transform: uppercase;
			letter-spacing: 1px;
			color: var(--accent-red);
			margin-bottom: 1.5rem;
			border-bottom: 1px solid var(--border);
			padding-bottom: 0.75rem;
		}

		.resume-content {
			margin: 1rem 0;
			padding-left: 1rem;
			border-left: 2px solid var(--border);
		}

		.resume-item {
			margin-bottom: 1rem;
		}

		.resume-item strong {
			color: var(--accent-green);
		}

		.contact-links {
			display: flex;
			gap: 2rem;
			flex-wrap: wrap;
			margin: 1rem 0;
		}

		a {
			color: var(--accent-red);
			text-decoration: none;
			transition: color 0.2s;
		}

		a:hover {
			color: var(--accent-bright-red);
		}

		.dial-in-btn {
			display: inline-block;
			margin-top: 3rem;
			padding: 0.5rem 1rem;
			border: 1px solid var(--text-muted);
			color: var(--text-muted);
			background: transparent;
			font-size: 0.9rem;
			font-weight: 400;
			cursor: pointer;
			letter-spacing: 0.5px;
			transition: all 0.2s;
			font-family: inherit;
		}

		.dial-in-btn:hover {
			background: var(--accent-red);
			color: var(--bg);
			box-shadow: 0 0 10px rgba(255, 0, 0, 0.5);
		}

		.dial-in-btn:active {
			opacity: 0.7;
		}

		@media (max-width: 640px) {
			.container {
				padding: 1.5rem;
			}

			.name {
				font-size: 1.8rem;
			}

			.dial-in-btn {
				width: 100%;
				text-align: center;
			}
		}

		/* BBS Styles */
		#bbs-root {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: var(--bg);
			z-index: 9999;
			overflow: hidden;
			display: none;
			flex-direction: column;
		}

		#bbs-root.bbs-active {
			display: flex;
		}

		.bbs-container {
			flex: 1;
			display: flex;
			flex-direction: column;
			overflow: hidden;
		}

		#dial-in-sequence,
		#main-menu,
		#menu-area {
			flex: 1;
			overflow-y: auto;
			padding: 1rem;
			font-family: "Courier New", monospace;
			font-size: 0.95rem;
			line-height: 1.8;
		}

		#dial-in-sequence {
			display: flex;
			align-items: center;
			justify-content: center;
			text-align: center;
		}

		#main-menu,
		#menu-area {
			display: none;
		}

		#main-menu.active,
		#menu-area.active {
			display: flex;
			flex-direction: column;
		}

		.hint-line {
			border-top: 1px solid var(--border);
			padding: 0.5rem 1rem;
			color: var(--text-muted);
			font-size: 0.85rem;
			background: rgba(0, 0, 0, 0.3);
		}

		@media (prefers-reduced-motion: reduce) {
			* {
				animation-duration: 0.01ms !important;
				animation-iteration-count: 1 !important;
				transition-duration: 0.01ms !important;
			}
		}
	</style>
</head>
