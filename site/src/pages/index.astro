	<script>
		class BBSController {
			constructor() {
				let hasSeenDial = false;
				try {
					hasSeenDial = localStorage.getItem("bbs:seen-dial") === "true";
				} catch (e) {
					console.warn("localStorage unavailable");
				}
				this.state = {
					mode: "dial-in",
					hasSeenDial: hasSeenDial,
				};

				this.root = document.getElementById("bbs-root");
				this.dialInSeq = document.getElementById("dial-in-sequence");
				this.mainMenu = document.getElementById("main-menu");
				this.menuArea = document.getElementById("menu-area");
				this.hintLine = document.getElementById("hint-line");

				this.setupEventListeners();
			}

			setupEventListeners() {
				document.getElementById("bbsLink")?.addEventListener("click", () => this.showBbs());
				window.addEventListener("keydown", (e) => this.handleKeydown(e));
			}

			handleKeydown(e) {
				if (!this.root?.classList.contains("bbs-active")) return;

				if (e.key === "Escape") {
					this.logOff();
					return;
				}

				if (this.state.mode === "dial-in") {
					if (e.key === " " || e.key === "Enter") {
						this.skipDial();
					}
					return;
				}

				const key = e.key;
				if (["1", "2", "3", "0"].includes(key)) {
					// Only allow specific keys in specific modes
					if (this.state.mode === "main-menu") {
						this.handleMenuSelection(key);
					} else if (this.state.mode === "message-board" && key === "1") {
						this.showPostView(0);
					} else if (this.state.mode === "message-board" && key === "0") {
						this.showMainMenu();
					} else if (this.state.mode === "post-view" && key === "0") {
						this.showMessageBoard();
					} else if (this.state.mode === "file-area" && key === "1") {
						window.location.href = "/ConnorDedicResume.pdf";
					} else if (this.state.mode === "file-area" && key === "0") {
						this.showMainMenu();
					} else if (this.state.mode === "whos-online" && key === "0") {
						this.showMainMenu();
					}
				}
			}

			showBbs() {
				document.body.classList.add("bbs-active");
				this.root?.classList.add("bbs-active");

				if (this.state.hasSeenDial) {
					this.showMainMenu();
				} else {
					this.showDialIn();
				}
			}

			showDialIn() {
				this.state.mode = "dial-in";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.remove("active");
				this.dialInSeq?.classList.add("active");

				this.renderDialIn();
			}

			renderDialIn() {
				const seq = [
					"",
					"",
					"CONNECT 56000",
					"CARRIER ESTABLISHED",
					"HANDSHAKE...",
					"",
					"",
					"       ◄ NETRUNNER INCOMING ►",
					"",
					"",
					"    WELCOME TO THE NETWORK",
					"    =========================",
					"",
					"",
					"[PRESS ANY KEY TO CONTINUE]",
					"",
				];

				this.dialInSeq.innerHTML = seq
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[SPACE/ENTER] skip");
			}

			skipDial() {
				try {
					localStorage.setItem("bbs:seen-dial", "true");
				} catch (e) {
					console.warn("localStorage unavailable");
				}
				this.state.hasSeenDial = true;
				this.showMainMenu();
			}

			showMainMenu() {
				this.state.mode = "main-menu";
				this.dialInSeq?.classList.remove("active");
				this.menuArea?.classList.remove("active");
				this.mainMenu?.classList.add("active");

				this.renderMainMenu();
			}

			renderMainMenu() {
				const banner = [
					"     ██╗   ██╗ ██████╗ ███████╗    ██╗   ██╗██╗██████╗ ███████╗███╗   ███╗██╗   ██╗███████╗",
					"     ██║   ██║██╔═══██╗██╔════╝    ██║   ██║██║██╔══██╗██╔════╝████╗ ████║██║   ██║██╔════╝",
					"     ██║   ██║██║   ██║███████╗    ██║   ██║██║██║  ██║█████╗  ██╔████╔██║██║   ██║███████╗",
					"╚██╗ ██╔╝██║   ██║╚════██║    ╚██╗ ██╔╝██║██║  ██║██╔══╝  ██║╚██╔╝██║██║   ██║╚════██║",
					" ╚████╔╝ ╚██████╔╝███████║     ╚████╔╝ ██║██████╔╝███████╗██║ ╚═╝ ██║╚██████╔╝███████║",
					"  ╚═══╝   ╚═════╝ ╚══════╝      ╚═══╝  ╚═╝╚═════╝ ╚══════╝╚═╝     ╚═╝ ╚═════╝ ╚══════╝",
					"",
					"┌────────────────────────────────────────────────────────────────────────────────────┐",
					"│                                                                                          │",
					"│  [ 1 ] MESSAGE BOARD                                                                        │",
					"│  [ 2 ] FILE AREA                                                                           │",
					"│  [ 3 ] WHO'S ONLINE                                                                      │",
					"│                                                                                             │",
					"│  [ 0 ] LOG OFF                                                                          │",
					"│                                                                                        │",
					"└────────────────────────────────────────────────────────────────────────────────────┘",
					"",
				];

				this.mainMenu.innerHTML = banner
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[1-3] select | [0] exit | [ESC] return");
			}

			handleMenuSelection(key) {
				if (this.state.mode === "message-board" && key === "0") {
					this.showMainMenu();
					return;
				}
				if (this.state.mode === "post-view" && key === "0") {
					this.showMessageBoard();
					return;
				}
				if (this.state.mode === "file-area" && key === "0") {
					this.showMainMenu();
					return;
				}
				if (this.state.mode === "whos-online" && key === "0") {
					this.showMainMenu();
					return;
				}

				switch (key) {
					case "1":
						this.showMessageBoard();
						break;
					case "2":
						this.showFileArea();
						break;
					case "3":
						this.showWhosOnline();
						break;
					case "0":
						this.logOff();
						break;
				}
			}


			showMessageBoard() {
				this.state.mode = "message-board";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"┌────────────────────────────────────────────────────────────────────────────────────┐",
					"│  MESSAGE BOARD                                                                  │",
					"├────────────────────────────────────────────────────────────────────────────────────┤",
					"│                                                                                  │",
					"│  [ 1 ] Active Directory Attacks                                   2026-06-20    │",
					"│                                                                                  │",
					"│  [1] read | [0] main menu                                                        │",
					"│                                                                                  │",
					"└────────────────────────────────────────────────────────────────────────────────────┘",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[1] read | [0] main menu | [ESC] exit");
			}

			wrapLines(text, width = 76) {
				const wrapped = [];
				const lines = text.split("\n");

				for (const line of lines) {
					if (line.length <= width) {
						wrapped.push(line);
					} else {
						let remaining = line;
						while (remaining.length > 0) {
							if (remaining.length <= width) {
								wrapped.push(remaining);
								break;
							}
							const breakPoint = remaining.lastIndexOf(" ", width) || width;
							wrapped.push(remaining.substring(0, breakPoint));
							remaining = remaining.substring(breakPoint).trim();
						}
					}
				}
				return wrapped;
			}

			showPostView(index) {
				this.state.mode = "post-view";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const posts = [
					{
						title: "Active Directory Attacks",
						content: `LAB ENVIRONMENT
