<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>Connor Dedic | Offensive Security Researcher</title>
	<style>
		:root {
			--bg: #0c0d10;
			--fg: #fefefe;
			--accent-red: #d10000;
			--text-muted: #888888;
			--border: #333333;
		}

		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html {
			color-scheme: dark;
		}

		body {
			background: var(--bg);
			color: var(--fg);
			font-family: "Courier New", monospace;
			line-height: 1.0;
			font-size: 14px;
			-webkit-text-size-adjust: 140%;
		}

		body.bbs-active {
			overflow: hidden;
		}

		.container {
			display: flex;
			align-items: center;
			justify-content: center;
			min-height: 100vh;
			padding: 2rem 1rem;
		}

		.portfolio-content {
			display: inline-block;
			text-align: left;
			white-space: pre-wrap;
			overflow-x: auto;
			font-family: "Courier New", monospace;
		}

		.portfolio-content pre {
			margin: 0;
			white-space: pre-wrap;
			word-wrap: break-word;
		}

		.header {
			text-align: center;
			margin-bottom: 2rem;
		}

		.name {
			font-size: 1.2rem;
			font-weight: 700;
			margin-bottom: 0.5rem;
			letter-spacing: 0;
		}

		.tagline {
			font-size: 0.9rem;
			color: var(--text-muted);
			margin-bottom: 1rem;
		}

		.bio {
			color: var(--fg);
			line-height: 1.5;
			margin: 1rem 0;
		}

		.section {
			margin: 1rem 0;
		}

		.section-title {
			font-size: 0.9rem;
			text-transform: uppercase;
			letter-spacing: 0;
			color: var(--fg);
			margin-bottom: 0.5rem;
		}

		.resume-content {
			margin: 0.5rem 0;
		}

		.resume-item {
			margin-bottom: 0.3rem;
		}

		.resume-item strong {
			color: var(--fg);
		}

		.contact-links {
			display: inline;
			margin: 0.5rem 0;
		}

		.contact-links a {
			margin-right: 2rem;
		}

		a {
			color: var(--accent-red);
			text-decoration: none;
		}

		a:hover {
			text-decoration: underline;
		}

		.dial-in-btn {
			display: block;
			margin-top: 1.5rem;
			padding: 0.3rem 0.8rem;
			border: 1px solid var(--accent-red);
			color: var(--accent-red);
			background: transparent;
			font-size: 0.9rem;
			font-weight: 400;
			cursor: pointer;
			letter-spacing: 0;
			transition: all 0.1s;
			font-family: "Courier New", monospace;
		}

		.dial-in-btn:hover {
			background: var(--accent-red);
			color: var(--bg);
		}

		.dial-in-btn:active {
			opacity: 0.7;
		}

		@media (max-width: 768px) {
			body {
				font-size: 13px;
			}

			.container {
				padding: 1rem;
			}
		}

		/* BBS Styles */
		#bbs-root {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: var(--bg);
			z-index: 9999;
			overflow: hidden;
			display: none;
			flex-direction: column;
		}

		#bbs-root.bbs-active {
			display: flex;
		}

		.bbs-container {
			flex: 1;
			display: flex;
			flex-direction: column;
			overflow: hidden;
		}

		#dial-in-sequence,
		#main-menu,
		#menu-area {
			flex: 1;
			overflow-y: auto;
			padding: 1rem;
			font-family: "Courier New", monospace;
			font-size: 14px;
			line-height: 1.0;
		}

		#dial-in-sequence {
			display: flex;
			align-items: center;
			justify-content: center;
			text-align: center;
		}

		#main-menu,
		#menu-area {
			display: none;
		}

		#main-menu.active,
		#menu-area.active {
			display: flex;
			flex-direction: column;
		}

		.hint-line {
			border-top: 1px solid var(--border);
			padding: 0.3rem 1rem;
			color: var(--text-muted);
			font-size: 12px;
			background: transparent;
		}

		@media (prefers-reduced-motion: reduce) {
			* {
				animation-duration: 0.01ms !important;
				animation-iteration-count: 1 !important;
				transition-duration: 0.01ms !important;
			}
		}
	</style>
</head>
