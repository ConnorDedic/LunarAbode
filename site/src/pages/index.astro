	<script>
		class BBS {
			constructor() {
				this.state = { mode: 'dial-in', seenDial: this.getSeen() };
				this.root = document.getElementById('bbs-root');
				this.content = document.getElementById('bbs-content');
				this.hint = document.getElementById('hint');
				document.getElementById('bbsLink').addEventListener('click', () => this.enter());
				window.addEventListener('keydown', e => this.handleKey(e));
			}
			getSeen() { try { return localStorage.getItem('bbs:seen') === '1'; } catch(e) { return false; } }
			setSeen() { try { localStorage.setItem('bbs:seen', '1'); } catch(e) {} }
			enter() { this.root.classList.add('active'); this.state.seenDial ? this.menu() : this.dial(); }
			dial() {
				this.state.mode = 'dial-in';
				this.content.textContent = '\n\nCONNECT 56000\nCARRIER ESTABLISHED\nHANDSHAKE...\n\n       ◄ NETRUNNER INCOMING ►\n\n    WELCOME TO THE NETWORK\n    =========================\n\n\n[PRESS ANY KEY TO CONTINUE]\n';
				this.hint.textContent = '[SPACE/ENTER] skip';
			}
			menu() {
				this.state.mode = 'menu';
				this.content.textContent = `██╗   ██╗ ██████╗ ███████╗    ██╗   ██╗██╗██████╗ ███████╗███╗   ███╗██╗   ██╗███████╗
