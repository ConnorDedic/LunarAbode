---
// Empty frontmatter - just render static HTML
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>Connor Dedic | Offensive Security Researcher</title>
	<style>
		:root {
			--bg: #0a0a0f;
			--fg: #e8e6d8;
			--accent-yellow: #fcee0a;
			--accent-magenta: #ff2e88;
			--accent-cyan: #00e5ff;
			--text-muted: #8a8a94;
			--border: #2a2a34;
		}

		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html {
			color-scheme: dark;
		}

		body {
			background: var(--bg);
			color: var(--fg);
			font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, monospace;
			line-height: 1.6;
		}

		body.bbs-active {
			overflow: hidden;
		}

		.container {
			max-width: 800px;
			margin: 0 auto;
			padding: 2rem;
			min-height: 100vh;
			display: flex;
			flex-direction: column;
			justify-content: space-between;
		}

		.header {
			padding: 3rem 0;
		}

		.name {
			font-size: 2.5rem;
			font-weight: 700;
			margin-bottom: 0.5rem;
			letter-spacing: -1px;
		}

		.tagline {
			font-size: 1.1rem;
			color: var(--text-muted);
			margin-bottom: 1rem;
		}

		.bio {
			color: var(--fg);
			line-height: 1.8;
			margin: 2rem 0;
		}

		.section {
			margin: 2rem 0;
		}

		.section-title {
			font-size: 0.9rem;
			text-transform: uppercase;
			letter-spacing: 1px;
			color: var(--accent-yellow);
			margin-bottom: 1rem;
			border-bottom: 1px solid var(--border);
			padding-bottom: 0.5rem;
		}

		.resume-content {
			margin: 1rem 0;
			padding-left: 1rem;
			border-left: 2px solid var(--border);
		}

		.resume-item {
			margin-bottom: 1rem;
		}

		.resume-item strong {
			color: var(--accent-cyan);
		}

		.contact-links {
			display: flex;
			gap: 2rem;
			flex-wrap: wrap;
			margin: 1rem 0;
		}

		a {
			color: var(--accent-yellow);
			text-decoration: none;
			transition: color 0.2s;
		}

		a:hover {
			color: var(--accent-magenta);
		}

		.dial-in-btn {
			display: inline-block;
			margin-top: 3rem;
			padding: 1rem 2rem;
			border: 2px solid var(--accent-yellow);
			color: var(--accent-yellow);
			background: transparent;
			font-size: 1.1rem;
			font-weight: 700;
			cursor: pointer;
			text-transform: uppercase;
			letter-spacing: 1px;
			transition: all 0.2s;
			font-family: inherit;
		}

		.dial-in-btn:hover {
			background: var(--accent-yellow);
			color: var(--bg);
			box-shadow: 0 0 20px rgba(252, 238, 10, 0.5);
		}

		.dial-in-btn:active {
			transform: scale(0.98);
		}

		@media (max-width: 640px) {
			.container {
				padding: 1.5rem;
			}

			.name {
				font-size: 1.8rem;
			}

			.dial-in-btn {
				width: 100%;
				text-align: center;
			}
		}

		/* BBS Styles */
		#bbs-root {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: var(--bg);
			z-index: 9999;
			overflow: hidden;
			display: none;
			flex-direction: column;
		}

		#bbs-root.bbs-active {
			display: flex;
		}

		.bbs-container {
			flex: 1;
			display: flex;
			flex-direction: column;
			overflow: hidden;
		}

		#dial-in-sequence,
		#main-menu,
		#menu-area {
			flex: 1;
			overflow-y: auto;
			padding: 1rem;
			font-family: "Courier New", monospace;
			font-size: 0.95rem;
			line-height: 1.8;
		}

		#dial-in-sequence {
			display: flex;
			align-items: center;
			justify-content: center;
			text-align: center;
		}

		#main-menu,
		#menu-area {
			display: none;
		}

		#main-menu.active,
		#menu-area.active {
			display: flex;
			flex-direction: column;
		}

		.hint-line {
			border-top: 1px solid var(--border);
			padding: 0.5rem 1rem;
			color: var(--text-muted);
			font-size: 0.85rem;
			background: rgba(0, 0, 0, 0.3);
		}

		@media (prefers-reduced-motion: reduce) {
			* {
				animation-duration: 0.01ms !important;
				animation-iteration-count: 1 !important;
				transition-duration: 0.01ms !important;
			}
		}
	</style>
</head>
<body>
	<div class="container">
		<div>
			<div class="header">
				<div class="name">CONNOR DEDIC</div>
				<div class="tagline">Offensive Security Researcher</div>
			</div>

			<div class="bio">
				Security researcher specializing in vulnerability research, exploit development, and CTF competitions. Currently exploring system security, reverse engineering, and attack surface analysis.
			</div>

			<div class="section">
				<div class="section-title">Resume Highlights</div>
				<div class="resume-content">
					<div class="resume-item">
						<strong>Certifications:</strong> OSCP, CEH, Security+
					</div>
					<div class="resume-item">
						<strong>Languages:</strong> Python, C, Rust, Go, JavaScript
					</div>
					<div class="resume-item">
						<strong>Focus Areas:</strong> Web security, binary exploitation, malware analysis
					</div>
				</div>
				<a href="/resume.pdf">↓ Download Full Resume (PDF)</a>
			</div>

			<div class="section">
				<div class="section-title">Contact</div>
				<div class="contact-links">
					<a href="mailto:connor@example.com">Email</a>
					<a href="https://github.com" target="_blank">GitHub</a>
					<a href="https://linkedin.com" target="_blank">LinkedIn</a>
				</div>
			</div>
		</div>

		<button class="dial-in-btn" id="dialInBtn">
			> DIAL IN
		</button>
	</div>

	<div id="bbs-root">
		<div class="bbs-container">
			<div id="dial-in-sequence"></div>
			<div id="main-menu"></div>
			<div id="menu-area"></div>
			<div class="hint-line" id="hint-line"></div>
		</div>
	</div>

	<script>
		class BBSController {
			constructor() {
				this.state = {
					mode: "dial-in",
					hasSeenDial: localStorage.getItem("bbs:seen-dial") === "true",
				};

				this.root = document.getElementById("bbs-root");
				this.dialInSeq = document.getElementById("dial-in-sequence");
				this.mainMenu = document.getElementById("main-menu");
				this.menuArea = document.getElementById("menu-area");
				this.hintLine = document.getElementById("hint-line");

				this.setupEventListeners();
			}

			setupEventListeners() {
				document.getElementById("dialInBtn")?.addEventListener("click", () => this.showBbs());
				window.addEventListener("keydown", (e) => this.handleKeydown(e));
			}

			handleKeydown(e) {
				if (!this.root?.classList.contains("bbs-active")) return;

				if (e.key === "Escape") {
					this.logOff();
					return;
				}

				if (this.state.mode === "dial-in") {
					if (e.key === " " || e.key === "Enter") {
						this.skipDial();
					}
					return;
				}

				const key = e.key;
				if (["1", "2", "3", "4", "5", "0"].includes(key)) {
					this.handleMenuSelection(key);
				}
			}

			showBbs() {
				document.body.classList.add("bbs-active");
				this.root?.classList.add("bbs-active");

				if (this.state.hasSeenDial) {
					this.showMainMenu();
				} else {
					this.showDialIn();
				}
			}

			showDialIn() {
				this.state.mode = "dial-in";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.remove("active");
				this.dialInSeq?.classList.add("active");

				this.renderDialIn();
			}

			renderDialIn() {
				const seq = [
					"CONNECT 56000",
					"CARRIER ESTABLISHED",
					"HANDSHAKE...",
					"",
					"       ◄ NETRUNNER INCOMING ►",
					"",
					"    WELCOME TO THE NETWORK",
					"    =========================",
					"",
					"[PRESS ANY KEY TO CONTINUE]",
				];

				this.dialInSeq.innerHTML = seq
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[SPACE/ENTER] skip");
			}

			skipDial() {
				localStorage.setItem("bbs:seen-dial", "true");
				this.state.hasSeenDial = true;
				this.showMainMenu();
			}

			showMainMenu() {
				this.state.mode = "main-menu";
				this.dialInSeq?.classList.remove("active");
				this.menuArea?.classList.remove("active");
				this.mainMenu?.classList.add("active");

				this.renderMainMenu();
			}

			renderMainMenu() {
				const menu = [
					"",
					"       ╔════════════════════════════╗",
					"       ║    MAINFRAME DIRECTORY     ║",
					"       ╚════════════════════════════╝",
					"",
					" [ 1 ] MESSAGE BOARD",
					" [ 2 ] FILE AREA",
					" [ 3 ] PROJECTS / WHO AM I",
					" [ 4 ] GUESTBOOK",
					" [ 5 ] WHO'S ONLINE",
					"",
					" [ 0 ] LOG OFF",
					"",
				];

				this.mainMenu.innerHTML = menu
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[1-5] select | [0] exit | [ESC] return");
			}

			handleMenuSelection(key) {
				switch (key) {
					case "1":
						this.showMessageBoard();
						break;
					case "2":
						this.showFileArea();
						break;
					case "3":
						this.showProjects();
						break;
					case "4":
						this.showGuestbook();
						break;
					case "5":
						this.showWhosOnline();
						break;
					case "0":
						this.logOff();
						break;
				}
			}

			showMessageBoard() {
				this.state.mode = "message-board";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"       ╔════════════════════════════╗",
					"       ║     MESSAGE BOARD          ║",
					"       ╚════════════════════════════╝",
					"",
					" [ 1 ] unpacking a loader           2026-06-12",
					" [ 2 ] exploit development tips     2026-06-05",
					" [ 3 ] ctf writeup: pwn2own         2026-05-28",
					"",
					"[1-3] read | [0] main menu",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] main menu | [ESC] exit");
			}

			showFileArea() {
				this.state.mode = "file-area";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"       ╔════════════════════════════╗",
					"       ║      FILE AREA             ║",
					"       ╚════════════════════════════╝",
					"",
					" [ 1 ] resume.pdf                 42 KB",
					" [ 2 ] ctf-writeups.zip          256 KB",
					" [ 3 ] projects on git.domain",
					"",
					"[1-3] select | [0] main menu",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] main menu | [ESC] exit");
			}

			showProjects() {
				this.state.mode = "projects";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"       ╔════════════════════════════╗",
					"       ║    PROJECTS / WHO AM I     ║",
					"       ╚════════════════════════════╝",
					"",
					" Security researcher diving deep into",
					" vulnerability research, exploit dev,",
					" and attack surface analysis.",
					"",
					" [ G ] View projects on Gitea",
					" [ 0 ] Main menu",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] main menu | [ESC] exit");
			}

			showGuestbook() {
				this.state.mode = "guestbook";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"       ╔════════════════════════════╗",
					"       ║      GUESTBOOK             ║",
					"       ╚════════════════════════════╝",
					"",
					" Last 5 visitors:",
					"",
					" > anonymouse (2026-06-29 14:22)",
					" > h4x0r_ph34r (2026-06-29 13:15)",
					" > netrunner99 (2026-06-29 11:08)",
					"",
					" [0] Main menu",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] main menu | [ESC] exit");
			}

			showWhosOnline() {
				this.state.mode = "whos-online";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"       ╔════════════════════════════╗",
					"       ║     WHO'S ONLINE           ║",
					"       ╚════════════════════════════╝",
					"",
					" > SYSOP (idle 2m)",
					" > you (active)",
					"",
					" [0] Main menu",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] main menu | [ESC] exit");
			}

			logOff() {
				document.body.classList.remove("bbs-active");
				this.root?.classList.remove("bbs-active");
				this.state.mode = "dial-in";
			}

			updateHint(text) {
				if (this.hintLine) {
					this.hintLine.textContent = text;
				}
			}

			escapeHtml(str) {
				const map = {
					"&": "&amp;",
					"<": "&lt;",
					">": "&gt;",
					'"': "&quot;",
					"'": "&#039;",
				};
				return str.replace(/[&<>"']/g, (char) => map[char]);
			}
		}

		document.addEventListener("DOMContentLoaded", () => {
			new BBSController();
		});
	</script>
</body>
</html>
