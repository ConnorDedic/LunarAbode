	<div id="bbs-root">
		<div class="bbs-container">
			<div id="dial-in-sequence"></div>
			<div id="main-menu"></div>
			<div id="menu-area"></div>
			<div class="hint-line" id="hint-line"></div>
		</div>
	</div>

	<script>
		class BBSController {
			constructor() {
				let hasSeenDial = false;
				try {
					hasSeenDial = localStorage.getItem("bbs:seen-dial") === "true";
				} catch (e) {
					console.warn("localStorage unavailable");
				}
				this.state = {
					mode: "dial-in",
					hasSeenDial: hasSeenDial,
				};

				this.root = document.getElementById("bbs-root");
				this.dialInSeq = document.getElementById("dial-in-sequence");
				this.mainMenu = document.getElementById("main-menu");
				this.menuArea = document.getElementById("menu-area");
				this.hintLine = document.getElementById("hint-line");

				this.setupEventListeners();
			}

			setupEventListeners() {
				document.getElementById("dialInBtn")?.addEventListener("click", () => this.showBbs());
				window.addEventListener("keydown", (e) => this.handleKeydown(e));
			}

			handleKeydown(e) {
				if (!this.root?.classList.contains("bbs-active")) return;

				if (e.key === "Escape") {
					this.logOff();
					return;
				}

				if (this.state.mode === "dial-in") {
					if (e.key === " " || e.key === "Enter") {
						this.skipDial();
					}
					return;
				}

				const key = e.key;
				if (["1", "2", "3", "4", "0"].includes(key)) {
					this.handleMenuSelection(key);
				}
			}

			showBbs() {
				document.body.classList.add("bbs-active");
				this.root?.classList.add("bbs-active");

				if (this.state.hasSeenDial) {
					this.showMainMenu();
				} else {
					this.showDialIn();
				}
			}

			showDialIn() {
				this.state.mode = "dial-in";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.remove("active");
				this.dialInSeq?.classList.add("active");

				this.renderDialIn();
			}

			renderDialIn() {
				const seq = [
					"",
					"",
					"CONNECT 56000",
					"CARRIER ESTABLISHED",
					"HANDSHAKE...",
					"",
					"",
					"       ◄ NETRUNNER INCOMING ►",
					"",
					"",
					"    WELCOME TO THE NETWORK",
					"    =========================",
					"",
					"",
					"[PRESS ANY KEY TO CONTINUE]",
					"",
				];

				this.dialInSeq.innerHTML = seq
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[SPACE/ENTER] skip");
			}

			skipDial() {
				try {
					localStorage.setItem("bbs:seen-dial", "true");
				} catch (e) {
					console.warn("localStorage unavailable");
				}
				this.state.hasSeenDial = true;
				this.showMainMenu();
			}

			showMainMenu() {
				this.state.mode = "main-menu";
				this.dialInSeq?.classList.remove("active");
				this.menuArea?.classList.remove("active");
				this.mainMenu?.classList.add("active");

				this.renderMainMenu();
			}

			renderMainMenu() {
				const banner = [
					"██╗   ██╗ ██████╗ ███████╗    ██╗   ██╗██╗██████╗ ███████╗███╗   ███╗██╗   ██╗███████╗",
					"██║   ██║██╔═══██╗██╔════╝    ██║   ██║██║██╔══██╗██╔════╝████╗ ████║██║   ██║██╔════╝",
					"██║   ██║██║   ██║███████╗    ██║   ██║██║██║  ██║█████╗  ██╔████╔██║██║   ██║███████╗",
					"╚██╗ ██╔╝██║   ██║╚════██║    ╚██╗ ██╔╝██║██║  ██║██╔══╝  ██║╚██╔╝██║██║   ██║╚════██║",
					" ╚████╔╝ ╚██████╔╝███████║     ╚████╔╝ ██║██████╔╝███████╗██║ ╚═╝ ██║╚██████╔╝███████║",
					"  ╚═══╝   ╚═════╝ ╚══════╝      ╚═══╝  ╚═╝╚═════╝ ╚══════╝╚═╝     ╚═╝ ╚═════╝ ╚══════╝",
					"",
					"┌────────────────────────────────────────────────────────────────────────────────────────────┐",
					"│                                                                                            │",
					"│  [ 1 ] ABOUT                                                                               │",
					"│  [ 2 ] EXPERIENCE                                                                          │",
					"│                                                                                            │",
					"│  [ 0 ] LOG OFF                                                                             │",
					"│                                                                                            │",
					"└────────────────────────────────────────────────────────────────────────────────────────────┘",
					"",
				];

				this.mainMenu.innerHTML = banner
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[1-2] select | [0] exit | [ESC] return");
			}

			handleMenuSelection(key) {
				if (this.state.mode === "about" && key === "0") {
					this.showMainMenu();
					return;
				}
				if (this.state.mode === "experience" && key === "0") {
					this.showMainMenu();
					return;
				}

				switch (key) {
					case "1":
						this.showAbout();
						break;
					case "2":
						this.showExperience();
						break;
					case "0":
						this.logOff();
						break;
				}
			}


			showAbout() {
				this.state.mode = "about";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"┌────────────────────────────────────────────────────────────────────────────────────────────┐",
					"│  ABOUT                                                                                     │",
					"├────────────────────────────────────────────────────────────────────────────────────────────┤",
					"│                                                                                            │",
					"│  Cyber Deception Engineer at Space Dynamics Laboratory.                                    │",
					"│                                                                                            │",
					"│  Specialized in Windows malware development, Active Directory exploitation, and           │",
					"│  offensive tooling. Contributing researcher on novel cyber deception techniques.          │",
					"│                                                                                            │",
					"│  SOC analyst, CTF creator, and BS Cybersecurity (BYU-Idaho, graduating July 2026).        │",
					"│                                                                                            │",
					"│  Skills span C, Python, Go, PowerShell, Bash, and JavaScript with deep expertise in       │",
					"│  AWS, Docker, Git, and Active Directory.                                                  │",
					"│                                                                                            │",
					"│  Certifications: AWS Cloud Practitioner, Security+, PenTest+, CySA+, PNPT.               │",
					"│                                                                                            │",
					"│  [ 0 ] MAIN MENU                                                                           │",
					"│                                                                                            │",
					"└────────────────────────────────────────────────────────────────────────────────────────────┘",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] main menu | [ESC] exit");
			}

			showExperience() {
				this.state.mode = "experience";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"┌────────────────────────────────────────────────────────────────────────────────────────────┐",
					"│  EXPERIENCE                                                                                │",
					"├────────────────────────────────────────────────────────────────────────────────────────────┤",
					"│                                                                                            │",
					"│  [ CURRENT ROLE ]                                                                          │",
					"│  Cyber Deception Engineer - Space Dynamics Laboratory (Jan–May 2026)                      │",
					"│  └─ Cataloged and developed cyber deception techniques                                     │",
					"│  └─ Conducted research on novel approaches across AI, ICS, AD, and bespoke systems        │",
					"│  └─ Contributing to upcoming published paper on cyber deception                           │",
					"│                                                                                            │",
					"│  [ EXPERTISE ]                                                                             │",
					"│                                                                                            │",
					"│  OFFENSIVE: Windows malware, AD exploitation, red team operations, reverse eng            │",
					"│  └─ Impacket, BloodHound, Mimikatz, Empire, custom tooling                                │",
					"│                                                                                            │",
					"│  DEFENSIVE: SOC operations, threat hunting, incident response, detection                  │",
					"│  └─ Splunk, Palo Alto, Crowdstrike, Suricata, Security Onion                             │",
					"│                                                                                            │",
					"│  [ 0 ] MAIN MENU                                                                           │",
					"│                                                                                            │",
					"└────────────────────────────────────────────────────────────────────────────────────────────┘",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] main menu | [ESC] exit");
			}


			logOff() {
				document.body.classList.remove("bbs-active");
				this.root?.classList.remove("bbs-active");
				this.state.mode = "dial-in";
			}

			updateHint(text) {
				if (this.hintLine) {
					this.hintLine.textContent = text;
				}
			}

			escapeHtml(str) {
				const map = {
					"&": "&amp;",
					"<": "&lt;",
					">": "&gt;",
					'"': "&quot;",
					"'": "&#039;",
				};
				return str.replace(/[&<>"']/g, (char) => map[char]);
			}
		}

		document.addEventListener("DOMContentLoaded", () => {
			new BBSController();
		});
	</script>
</body>
</html>
