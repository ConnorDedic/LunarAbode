					{ id: 6, title: 'Windows Structures & Data Types', date: '2026-06-20' },
					{ id: 7, title: 'Active Directory Attacks', date: '2026-06-20' },
					{ id: 8, title: 'Web Application Attacks', date: '2026-06-20' },
					{ id: 9, title: 'Penetration Testing Tradecraft', date: '2026-06-20' }
				];
				document.getElementById('bbsLink').addEventListener('click', () => this.enter());
				window.addEventListener('keydown', e => this.handleKey(e));
			}
			getSeen() { try { return localStorage.getItem('bbs:seen') === '1'; } catch(e) { return false; } }
			setSeen() { try { localStorage.setItem('bbs:seen', '1'); } catch(e) {} }
			enter() { this.root.classList.add('active'); this.state.seenDial ? this.menu() : this.dial(); }
			dial() {
				this.state.mode = 'dial-in';
