sudo mitm6 -d <domain>
impacket-ntlmrelayx -6 -t ldaps://<DC-IPv4> -wh <fakeservice>.<domain>.local -l <loot>`
					}
				];

				const post = posts[index];
				const wrappedLines = this.wrapLines(post.content, 76);
				const content = [
					"",
					"┌────────────────────────────────────────────────────────────────────────────────────┐",
					`│  ${post.title.padEnd(76)} │`,
					"├────────────────────────────────────────────────────────────────────────────────────┤",
					"│                                                                                  │",
					...wrappedLines.map(line => {
						const padded = line.padEnd(76);
						return `│  ${padded} │`;
					}),
					"│                                                                                  │",
					"│  [ 0 ] back to message board                                                    │",
					"│                                                                                  │",
					"└────────────────────────────────────────────────────────────────────────────────────┘",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] back | [ESC] exit");
			}

			showFileArea() {
				this.state.mode = "file-area";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"┌────────────────────────────────────────────────────────────────────────────────────┐",
					"│  FILE AREA                                                                      │",
					"├────────────────────────────────────────────────────────────────────────────────────┤",
					"│                                                                                  │",
					"│  [ 1 ] ConnorDedicResume.pdf                                         120 KB    │",
					"│                                                                                  │",
					"│  [1] select | [0] main menu                                                     │",
					"│                                                                                  │",
					"└────────────────────────────────────────────────────────────────────────────────────┘",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] main menu | [ESC] exit");
			}

			showWhosOnline() {
				this.state.mode = "whos-online";
				this.mainMenu?.classList.remove("active");
				this.menuArea?.classList.add("active");

				const content = [
					"",
					"┌────────────────────────────────────────────────────────────────────────────────────┐",
					"│  WHO'S ONLINE                                                                   │",
					"├────────────────────────────────────────────────────────────────────────────────────┤",
					"│                                                                                  │",
					"│  > SYSOP (San Diego, CA - idle 2m)                                             │",
					"│  > you (San Diego, CA - active)                                                │",
					"│  > netrunner (Tokyo, JP - active)                                              │",
					"│  > h4x0r (Berlin, DE - idle 8m)                                                │",
					"│  > cipher (London, UK - active)                                                │",
					"│                                                                                  │",
					"│  [ 0 ] main menu                                                                │",
					"│                                                                                  │",
					"└────────────────────────────────────────────────────────────────────────────────────┘",
					"",
				];

				this.menuArea.innerHTML = content
					.map((line) => `<div>${this.escapeHtml(line)}</div>`)
					.join("");

				this.updateHint("[0] main menu | [ESC] exit");
			}


			logOff() {
				document.body.classList.remove("bbs-active");
				this.root?.classList.remove("bbs-active");
				this.state.mode = "dial-in";
			}

			updateHint(text) {
				if (this.hintLine) {
					this.hintLine.textContent = text;
				}
			}

			escapeHtml(str) {
				const map = {
					"&": "&amp;",
					"<": "&lt;",
					">": "&gt;",
					'"': "&quot;",
					"'": "&#039;",
				};
				return str.replace(/[&<>"']/g, (char) => map[char]);
			}
		}

		document.addEventListener("DOMContentLoaded", () => {
			new BBSController();
		});
	</script>
</body>
</html>
