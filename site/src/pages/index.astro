				}
			}

			escapeHtml(str) {
				const map = {
					"&": "&amp;",
					"<": "&lt;",
					">": "&gt;",
					'"': "&quot;",
					"'": "&#039;",
				};
				return str.replace(/[&<>"']/g, (char) => map[char]);
			}
		}

		document.addEventListener("DOMContentLoaded", () => {
			new BBSController();
		});
	</script>
</body>
</html>
