│  GUIDES & NOTES                                                             │
├──────────────────────────────────────────────────────────────────────────────┤
│                                                                              │
`;
				this.guides.forEach(guide => {
					const paddedNum = String(guide.id).padEnd(2);
					const paddedTitle = guide.title.padEnd(50);
					listing += `│  [ ${paddedNum} ] ${paddedTitle} ${guide.date}        │
`;
				});
				listing += `│                                                                              │
│  [1-${String(this.guides.length).padEnd(1)}] read | [0] main menu                                                  │
│                                                                              │
└──────────────────────────────────────────────────────────────────────────────┘`;
				this.content.textContent = listing;
				this.hint.textContent = `[1-${this.guides.length}] select | [0] main menu`;
			}
			viewpost() {
				this.state.mode = 'post';
				const message = `System Announcements

This is the message board.
Post announcements and discussions here.`;
				this.currentPostLines = message.split('\n');
				const endLine = Math.min(this.currentPostOffset + 20, this.currentPostLines.length);
				const displayLines = this.currentPostLines.slice(this.currentPostOffset, endLine);
				const displayText = displayLines.join('\n');
				const pageNum = Math.floor(this.currentPostOffset / 20) + 1;
				const totalPages = Math.ceil(this.currentPostLines.length / 20);
				this.content.textContent = displayText;
				this.hint.textContent = `[PgUp/PgDn] scroll (${pageNum}/${totalPages}) | [0] back`;
			}
