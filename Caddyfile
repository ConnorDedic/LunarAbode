# Production setup for vosvidemus.online:
vosvidemus.online {
	handle /api/* {
		reverse_proxy guides:3001
	}
	reverse_proxy site:80
}

# Also handle www subdomain:
www.vosvidemus.online {
	handle /api/* {
		reverse_proxy guides:3001
	}
	reverse_proxy site:80
}

# Development fallback:
:80 {
	reverse_proxy site:80
}

# Production setup - customize for your domain:
# yourdomain.com {
#     reverse_proxy site:80
# }
